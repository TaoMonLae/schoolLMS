# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Must start with postgresql://
# Production example: postgresql://schoolos:strongpassword@localhost:5432/refugee_schoolos?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/refugee_schoolos?schema=public"

# ── Session / Auth ────────────────────────────────────────────────────────────
# REQUIRED: Used to sign/verify session cookies.
# Generate with: openssl rand -base64 48
# Must be at least 32 characters.
NEXTAUTH_SECRET="replace-with-a-long-random-secret-min-32-chars"

# REQUIRED: The public URL of your application.
# Development: http://localhost:3000
# Production: https://refugeeschoolos.com
NEXTAUTH_URL="http://localhost:3000"

# Migration note: The current implementation uses a base64url cookie session
# (see lib/session.ts). For production, migrate to NextAuth.js:
#   npm install next-auth @auth/prisma-adapter
# Then configure your auth provider in app/api/auth/[...nextauth]/route.ts

# ── Multi-school SaaS ─────────────────────────────────────────────────────────
# Base domain used for subdomain routing: {school}.{BASE_DOMAIN}
# Production: refugeeschoolos.com
# Local dev with subdomain testing:
#   1. Add to /etc/hosts: 127.0.0.1 monrlc.localhost
#   2. Set NEXT_PUBLIC_BASE_DOMAIN=localhost
#   3. Visit http://monrlc.localhost:3000/dashboard
NEXT_PUBLIC_BASE_DOMAIN="refugeeschoolos.com"

# ── Password hashing ──────────────────────────────────────────────────────────
# bcrypt cost factor. Higher = slower hash = harder to brute-force.
# Recommended: 12 (≈250ms on modern hardware). Valid range: 10–14.
BCRYPT_ROUNDS="12"

# ── Audit log retention ───────────────────────────────────────────────────────
# How many days to retain audit log entries.
# Longer retention is better for compliance; shorter saves disk space.
AUDIT_LOG_RETENTION_DAYS="365"

# ── Rate limiting ─────────────────────────────────────────────────────────────
# For single-instance deployments, the in-memory rate limiter in
# lib/rate-limit.ts is used automatically.
#
# For multi-instance deployments (PM2 cluster, multiple Droplets):
# Set these to use Upstash Redis as the shared rate limit store.
# Get credentials at: https://console.upstash.com
# UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"

# ── File uploads (school logos, library books, etc.) ─────────────────────────
# Set your object storage credentials when wiring up file uploads.
# Supported: AWS S3, Cloudflare R2 (use AWS SDK with custom endpoint), MinIO.
#
# The school logo field currently accepts a public HTTPS URL.
# For production, implement server-side upload using lib/upload-validation.ts
# to verify magic bytes before storing files.
#
# STORAGE_BUCKET=""
# STORAGE_REGION=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""
# STORAGE_PUBLIC_URL=""
# STORAGE_ENDPOINT=""    # For R2: https://<account-id>.r2.cloudflarestorage.com

# ── Backup ────────────────────────────────────────────────────────────────────
# See scripts/backup.sh for usage. These are read by the backup script,
# not by the Next.js application.
#
# BACKUP_DIR="/var/backups/schoolos"
# RETENTION_DAYS="30"
# BACKUP_S3_BUCKET="schoolos-backups"   # If set, uploads backup to S3/R2
